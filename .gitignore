.env
.env.*
!.env.example
.env.local
.env.*.local
**/.env
**/.env.local

# Coverage / profiling (tools in requirements / local runs)
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# Optional: screenshot / automation output if generated from this repo
/screenshots/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
