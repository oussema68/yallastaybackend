# Node (frontend lives in sibling repo; ignore accidental npm installs under ``yallastay/``)
node_modules/

# Python
__pycache__/
*.py[cod]
*.so
.Python
venv/
env/
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Django / local DB
*.log
*.sqlite3
*.sqlite3-journal
# MEDIA_ROOT / STATIC_ROOT next to manage.py; uploads & collectstatic are local/deploy artifacts only
