# Copy this file to ".env" in this directory (same folder as manage.py).
# Never commit ".env" - it is gitignored.
#
# Django refuses to start without SECRET_KEY. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(40))"

# --- Required ---
DJANGO_ENV=dev
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000

# --- Site ---
LANGUAGE_CODE=en-us
TIME_ZONE=Asia/Dubai

# --- Optional: dev CORS (comma-separated). Required for local dev — see values above. ---
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- PostgreSQL (production / staging) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_PRIVATE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_CONN_MAX_AGE=600

# Row Level Security (PostgreSQL): set false only for emergencies
# POSTGRES_RLS_ENABLED=true

# --- Railway / public demo (two hosts: SPA + API) ---
# Django loads prod settings when RAILWAY_* or DATABASE_URL is set; see yallastay/settings/__init__.py
# FRONTEND_URL=https://your-spa-service.up.railway.app
# BACKEND_URL=https://your-api-service.up.railway.app
# ALLOWED_HOSTS=your-api-service.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-spa-service.up.railway.app
# DATABASE_URL=postgresql://...   (Railway Postgres plugin)
#
# One-shot demo seeds after deploy (Railway shell, cwd = this folder): python manage.py bootstrap_demo
#
# Frontend SPA must be built with absolute API base (not /api proxy):
#   VITE_API_URL=https://your-api-service.up.railway.app/api npm run build

# --- Production hosts & CORS (comma-separated) ---
# ALLOWED_HOSTS=api.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com

# --- User uploads (images, PDFs): NOT stored as blobs in PostgreSQL ---
# DB rows hold paths/keys only. Default: local folder ``yallastay/media/``.
# Production: S3-compatible bucket (signed URLs in API responses).
# USE_S3_MEDIA=false
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=me-central-1
# Optional CloudFront / custom hostname for object URLs:
# AWS_S3_CUSTOM_DOMAIN=cdn.example.com

# --- Email ---
# Backend is auto-selected (do NOT set EMAIL_BACKEND):
#   RESEND_API_KEY set   -> Resend HTTPS API (recommended for Railway / production)
#   EMAIL_HOST_USER set  -> SMTP (auto-forced to IPv4 on Railway; usually leave unset)
#   neither              -> console (emails printed to stdout; default for local dev)
DEFAULT_FROM_EMAIL=noreply@yallastay.local
YALLASTAY_TEAM_USER_EMAIL=yallastay-team@internal.yallastay
# VERIFICATION_TEAM_EMAIL=verification@yourcompany.com

# --- Production email via Resend HTTPS API (recommended) ---
# 1. Verify your domain in Resend and add a sender (e.g. demo@yallastay.ae).
# 2. Create an API key (starts with "re_"); set RESEND_API_KEY on Railway only (never commit).
# 3. DEFAULT_FROM_EMAIL must be an address on that verified domain.
# Full steps: docs/RESEND_SETUP.md
#
# DEFAULT_FROM_EMAIL=demo@yallastay.ae
# RESEND_API_KEY=re_xxxxxxxx

# --- Optional SMTP fallback (use instead of RESEND_API_KEY) ---
# On Railway this is auto-forced to IPv4 (no IPv6 egress). Set EMAIL_SMTP_USE_IPV4=false to disable.
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxx
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_TIMEOUT=15

# --- Payments (set in deployment; never commit real values) ---
PAYMENT_PROVIDER=stub
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# Stub provider only: prefix for the fake client token (not a live API secret)
STUB_CHECKOUT_CLIENT_TOKEN_PREFIX=stub_checkout_token

# Stub webhook hardening: if set, anonymous POST /api/payments/webhook/stub/ must send header
# X-Stub-Webhook-Secret with this exact value (or caller must be JWT auth as the payment owner).
# Frontend: set the same value in VITE_STUB_WEBHOOK_SECRET so the SPA sends the header.
# STUB_WEBHOOK_SECRET=

# --- SendGrid webhook (optional) ---
# SENDGRID_WEBHOOK_SECRET=

# --- Twilio SMS (optional) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# --- JWT (optional) ---
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# --- API throttling (optional; DRF rate strings) ---
# API_THROTTLE_ANON=100/minute
# API_THROTTLE_USER=1000/day
# Auth endpoints (ScopedRateThrottle; see docs/security/auth-hardening-idor-rls.md)
# API_THROTTLE_AUTH_LOGIN=5/minute
# API_THROTTLE_AUTH_REGISTER=5/minute
# API_THROTTLE_AUTH_REFRESH=30/minute
# API_THROTTLE_AUTH_PASSWORD_RESET=5/hour
# API_THROTTLE_AUTH_PASSWORD_RESET_CONFIRM=10/minute
# API_THROTTLE_AUTH_VERIFY_EMAIL=60/minute
# API_THROTTLE_AUTH_RESEND_VERIFICATION=5/hour

# --- E-sign (optional) ---
# ESIGN_AUTO_GENERATE_CONTRACT_PDF=false
# ESIGN_LEASE_UPLOAD_MAX_BYTES=15728640
# ESIGN_SIGNATURE_MIN_BYTES=250
# ESIGN_SIGNATURE_MAX_BYTES=524288
# ESIGN_SIGNATURE_MIN_WIDTH=20
# ESIGN_SIGNATURE_MIN_HEIGHT=10
# ESIGN_SIGNATURE_MAX_WIDTH=4000
# ESIGN_SIGNATURE_MAX_HEIGHT=2000
